# Neon PostgreSQL connection string (copie desde su dashboard en neon.tech)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Puerto local (Render asigna su propio PORT automaticamente)
PORT=3000

# SSL: false solo para PostgreSQL local sin SSL, true (o dejar vacio) para Neon
DB_SSL=true

# Para hosting con SSL (Azure, Railway, etc.) ponga true
DB_ENCRYPT=false

# Puerto del servidor web
PORT=3000
